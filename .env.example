# Smakaduta.ai — Environment Variables
# Copy this file to .env.local and fill in the values

# ═══════════════════════════════════════════
# OpenRouter API (Chat & Embedding Models)
# Get your key at: https://openrouter.ai/keys
# ═══════════════════════════════════════════
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxx

# ═══════════════════════════════════════════
# Neon Database (Serverless Postgres + pgvector)
# Get your connection string at: https://neon.tech
# Format: postgresql://user:pass@host/dbname?sslmode=require
# ═══════════════════════════════════════════
DATABASE_URL=postgresql://user:password@ep-xxxxx.region.aws.neon.tech/neondb?sslmode=require

# ═══════════════════════════════════════════
# Vercel AI Gateway (Optional - for caching)
# Get your key at: https://vercel.com/ai/api-keys
# ═══════════════════════════════════════════
AI_GATEWAY_API_KEY=

# ═══════════════════════════════════════════
# Admin Authentication
# Set a strong password for admin dashboard access
# ═══════════════════════════════════════════
ADMIN_SECRET=your-super-secret-admin-password-here
